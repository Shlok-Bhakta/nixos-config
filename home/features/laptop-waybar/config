[
  {
    "output": [
      "eDP-1"
    ],
    "height": 32,
    "spacing": 10,
    "modules-left": [
      "hyprland/workspaces",
      "custom/media"
    ],
    "modules-center": [
      "clock"
    ],
    "modules-right": [
      "custom/weather",
      "network",
      "pulseaudio",
      "backlight",
      "custom/power-profile",
      "battery",
      "custom/notification",
      "tray"
    ],
    "hyprland/workspaces": {
      "format": "{name}",
      "on-click": "activate",
      "sort-by-number": true,
      "on-scroll-up": "hyprctl dispatch workspace e+1",
      "on-scroll-down": "hyprctl dispatch workspace e-1",
      "all-outputs": false
    },
    "custom/media": {
      "format": "яАБ  {}",
      "escape": true,
      "max-length": 40,
      "on-click": "playerctl play-pause",
      "on-click-right": "playerctl stop",
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous",
      "interval": 10,
      "exec": "playerctl status | grep -q 'Stopped' && echo '' || playerctl metadata -f '{{xesam:artist}}:{{xesam:title}}'"
    },
    "clock": {
      "interval": 1,
      "format": "{:%I:%M %p  %A %b %d}",
      "format-alt": "{:%I:%M %p  %Y-%m-%d}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/weather": {
      "format": "{}",
      "interval": 3600,
      "exec": "curl -s 'https://wttr.in/?format=1' | sed 's/   / /g' | sed 's/+//g'",
      "exec-if": "ping wttr.in -c1",
      "tooltip-format": "{}"
    },
    "network": {
      "format-wifi": "яЗл {essid} ({signalStrength}%)",
      "format-ethernet": "тмЗ{bandwidthDownBytes} тмЖ{bandwidthUpBytes}",
      "interval": 3,
      "format-linked": "{ifname} (No IP) яЮЦ",
      "format": "яАТ",
      "format-disconnected": "яЪФ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}",
      "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
      "tooltip-format": "яВУ {bandwidthUpBits} яАЩ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}\n",
      "tooltip-format-wifi": "яЗл {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nяВУ {bandwidthUpBits} яАЩ {bandwidthDownBits}",
      "min-length": 17,
      "max-length": 17
    },
    "pulseaudio": {
      "format": "{icon} {volume}% {format_source}",
      "format-bluetooth": "яКФ {icon} {volume}% {format_source}",
      "format-bluetooth-muted": "яЪй яКФ {icon} {format_source}",
      "format-muted": "яЪй  {format_source}",
      "format-source": "яД░ {volume}%",
      "format-source-muted": "яД▒",
      "format-icons": {
        "default": [
          "яАж",
          "яАз",
          "яАи "
        ]
      },
      "scroll-step": 1,
      "on-click": "pavucontrol"
    },
    "tray": {
      "spacing": 8
    },
    "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": [
        "юОН",
        "юПУ",
        "юПС",
        "юПП",
        "юПО",
        "юПН",
        "юПК",
        "юПИ",
        "юОЫ"
      ]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "ґ░вЬ {capacity}%",
      "format-plugged": "яЗж {capacity}%",
      "format-icons": [
        "яЙД",
        "яЙГ",
        "яЙВ",
        "яЙБ",
        "яЙА"
      ],
      "on-click": "ags -t quicksettings"
    },
    "custom/power-profile": {
      "exec": "power-profile-status",
      "return-type": "json",
      "interval": 5,
      "format": "{}"
    },
    "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
        "notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
        "none": "яВв",
        "dnd-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
        "dnd-none": "яЗ╖"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
    },
    "custom/rightpad": {
      "format": " "
    }
  },
